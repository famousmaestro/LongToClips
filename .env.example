# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# QUEUE_DRIVER: Use 'memory' for local preview or 'redis' for production bullmq
QUEUE_DRIVER="memory"

# REDIS_URL: Required if QUEUE_DRIVER is redis
REDIS_URL="redis://localhost:6379"

# STORAGE_DRIVER: Use 'local' for container file system or 's3' for production Object Storage
STORAGE_DRIVER="local"

# AWS_ACCESS_KEY_ID: Required if STORAGE_DRIVER is s3
AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY: Required if STORAGE_DRIVER is s3
AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET: Required if STORAGE_DRIVER is s3
AWS_S3_BUCKET=""
